rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function loggedIn() { return request.auth != null; }
    
    // DECISÃO DEFINITIVA DE SEGURANÇA: O bypass 'uid == tenantId' é intencional e definitivo.
    // Ele impede que o proprietário raiz da conta (Owner principal do Tenant) seja acidentalmente
    // desativado por outros administradores ou falhas em coleções de membros secundários.
    // Risco: O owner principal não pode ser desativado via coleção de membros.
    // Mitigação: O cancelamento ou suspensão da conta do Tenant é feito desativando ou excluindo 
    // o próprio documento pai '/tenants/{tenantId}', o que revoga imediatamente o acesso geral.
    
    // Check if user is a member of the tenant with a valid role and is active
    function isMember(tenantId) {
      return loggedIn() && 
        (request.auth.uid == tenantId || 
         (exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.active == true));
    }
    
    // Check if user is the tenant owner or admin specifically and is active
    function isOwnerOrAdmin(tenantId) {
      return loggedIn() && 
        (request.auth.uid == tenantId || 
         (exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.active == true &&
          get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.role in ['owner', 'admin']));
    }

    match /{document=**} { allow read, write: if false; }

    // Tenant configuration access
    match /tenants/{tenantId} {
      allow read: if loggedIn() && isMember(tenantId);
      allow write: if loggedIn() && isOwnerOrAdmin(tenantId);
      
      // Members subcollection
      match /members/{uid} {
        allow read: if loggedIn() && isMember(tenantId);
        allow write: if loggedIn() && isOwnerOrAdmin(tenantId);
      }
    }

    // Pets collection
    match /pets/{petId} {
      allow get: if loggedIn() && (isMember(resource.data.tenant_id) || isMember(resource.data.tenantId));
      allow list: if loggedIn() && (isMember(resource.data.tenant_id) || isMember(resource.data.tenantId));
      allow create: if loggedIn() && (isMember(request.resource.data.tenant_id) || isMember(request.resource.data.tenantId));
      allow update: if loggedIn() && (isMember(resource.data.tenant_id) || isMember(resource.data.tenantId)) && (isMember(request.resource.data.tenant_id) || isMember(request.resource.data.tenantId));
      allow delete: if loggedIn() && (isMember(resource.data.tenant_id) || isMember(resource.data.tenantId));
    }

    // Subcollections of pets (timeline, moments, boletins) are protected!
    // No more public read ("allow read: if true")! Tutors access them solely via the secure backend API.
    match /pets/{petId}/timeline/{id} {
      allow read, write: if loggedIn() && isMember(get(/databases/$(database)/documents/pets/$(petId)).data.tenant_id);
    }
    match /pets/{petId}/moments/{id} {
      allow read, write: if loggedIn() && isMember(get(/databases/$(database)/documents/pets/$(petId)).data.tenant_id);
    }
    match /pets/{petId}/boletins/{id} {
      allow read, write: if loggedIn() && isMember(get(/databases/$(database)/documents/pets/$(petId)).data.tenant_id);
    }

    // Secure tutorAccessLinks are completely blocked from client-side direct SDK reads and writes
    match /tutorAccessLinks/{hash} {
      allow read, write: if false; // All operations must go through Admin SDK on the server
    }

    // tenantAuditLogs is completely secure
    match /tenantAuditLogs/{logId} {
      allow read, write: if false; // Only backend admin SDK can query and write audit logs
    }

    // Staging IP Telemetry collection (accessible ONLY to administrators via Cloud Console / Admin SDK)
    match /staging_ip_telemetry/{id} {
      allow read, write: if false; // Block client-side SDK completely. Only readable via Admin SDK.
    }

    // Registros
    match /registros/{regId} {
      allow read, delete: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
    }

    // Checklists
    match /checklists/{checklistId} {
      allow read: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
      allow delete: if loggedIn() && isOwnerOrAdmin(resource.data.tenant_id);
    }

    // Groups
    match /groups/{groupId} {
      allow read, delete: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
    }

    // Medications
    match /medications/{medId} {
      allow read: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
      allow delete: if loggedIn() && isOwnerOrAdmin(resource.data.tenant_id);
    }

    // Medication logs
    match /medication_logs/{logId} {
      allow read: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
      allow delete: if loggedIn() && isOwnerOrAdmin(resource.data.tenant_id);
    }

    // Public pending registrations
    match /cadastros_pendentes/{id} {
      // Allows anyone to create/submit (public registration form), but validation is enforced
      allow create: if request.resource.data.tenant_id != null;
      allow read, delete: if loggedIn() && isMember(resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
    }

    // Hotel Stays
    match /hotelStays/{stayId} {
      allow read: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
      allow delete: if loggedIn() && isOwnerOrAdmin(resource.data.tenant_id);
    }

    // Hotel Records
    match /hotelRecords/{recordId} {
      allow read: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
      allow delete: if loggedIn() && isOwnerOrAdmin(resource.data.tenant_id);
    }

    // Hotel Reports
    match /hotelReports/{reportId} {
      allow read: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
      allow delete: if loggedIn() && isOwnerOrAdmin(resource.data.tenant_id);
    }

    // Boletins
    match /boletins/{boletimId} {
      allow read: if loggedIn() && isMember(resource.data.tenant_id);
      allow create: if loggedIn() && isMember(request.resource.data.tenant_id);
      allow update: if loggedIn() && isMember(resource.data.tenant_id) && isMember(request.resource.data.tenant_id);
      allow delete: if loggedIn() && isOwnerOrAdmin(resource.data.tenant_id);
    }
  }
}
